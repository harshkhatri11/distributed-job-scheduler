# ── Database ──────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/job_scheduler
DB_USERNAME=
DB_PASSWORD=

# ── Docker Postgres ───────────────────────────────────────────
POSTGRES_DB=job_scheduler
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Zookeeper ─────────────────────────────────────────────────
ZOOKEEPER_CLIENT_PORT=2181

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Observability ─────────────────────────────────────────────
LOKI_URL=http://localhost:3100
ZIPKIN_BASE_URL=http://localhost:9411   # change to your Zipkin host in production

# ── Prometheus scrape targets ─────────────────────────────────
SCHEDULER_HOST=host.docker.internal   # change to container name in production
SCHEDULER_PORT=8080
WORKER_HOST=host.docker.internal      # change to container name in production
WORKER_PORT=8081

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=                     # choose a strong password; never commit the real value

# ── Alertmanager ──────────────────────────────────────────────
SLACK_WEBHOOK_URL=                    # your Slack incoming webhook URL